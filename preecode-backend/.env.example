PORT=
MONGO_URI=
JWT_SECRET=
FRONTEND_URL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NODE_ENV=production

# Optional for local frontend development only.
FRONTEND_DEV_URL=

# Optional when serving static assets from the backend.
FRONTEND_STATIC_PATH=

# Required for Google OAuth callback generation unless GOOGLE_CALLBACK_URL is set explicitly.
BACKEND_URL=

# Optional explicit override for Google OAuth callback.
GOOGLE_CALLBACK_URL=

# OpenRouter API configuration
OPENROUTER_API_KEY=

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SendGrid (for emails)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
